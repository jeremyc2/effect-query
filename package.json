{
	"name": "effect-query",
	"module": "index.ts",
	"scripts": {
		"typecheck": "tsgo && bun --cwd examples/react-bun typecheck",
		"all": "bun typecheck && bun check && bun test",
		"example:react-bun": "bun --cwd examples/react-bun dev",
		"check": "bun --bun biome check --write && bun --bun oxlint -c .oxlintrc.jsonc",
		"reference:update": "git submodule update --init --remote reference_repositories/effect-smol reference_repositories/query",
		"prepare": "effect-tsgo patch",
		"chore:update": "bun update --latest && bun add effect@beta @effect/platform-bun@beta"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@effect/language-service": "^0.85.1",
		"@effect/tsgo": "^0.5.2",
		"@oxlint/plugins": "^1.63.0",
		"@types/bun": "1.3.13",
		"@typescript/native-preview": "^7.0.0-dev.20260509.2",
		"oxlint": "^1.63.0"
	},
	"private": true,
	"type": "module",
	"dependencies": {
		"@effect/platform-bun": "^4.0.0-beta.64",
		"effect": "^4.0.0-beta.64"
	}
}
